{#
/**
 * @file
 * Theme implementation for KoRe paragraph types displayed as list items.
 *
 * Used for: kore_archive, kore_building, kore_field, kore_gender, kore_language,
 * kore_name, kore_principal, kore_type.
 *
 * Renders as <li> for semantic list structure within field--node--kore-school.
 *
 * @see template_preprocess_paragraph()
 * @see field--node--kore-school.html.twig
 */
#}
{%
  set classes = [
    'kore--field-item',
    'paragraph',
    'paragraph--type--kore',
    'paragraph--type--' ~ paragraph.bundle|clean_class,
    view_mode ? 'paragraph--view-mode--' ~ view_mode|clean_class,
    not paragraph.isPublished() ? 'paragraph--unpublished'
  ]
%}
<li{{ attributes.addClass(classes) }}>
  <span class="kore--content">
    {% if paragraph.bundle == 'kore_archive' %}
      {{ content.field_kore_archive }}
      <div class="kore--archive-link"> {{ content.field_kore_url }}</div>
    {% else %}
      {{ content|without('field_kore_start_year', 'field_kore_end_year', 'field_kore_addresses') }}
      {% for address in paragraph.field_kore_addresses %}
        <span class="kore--address">{{ address.entity.field_kore_address.value }}</span>{% if not loop.last %} → {% endif %}
      {% endfor %}
      {% if paragraph.field_kore_addresses|length > 0 %}
        <span class="kore--show-on-map">
          {% set last_address = paragraph.field_kore_addresses|last %}
          {{ last_address.entity.field_kore_geofield|view('default') }}
        </span>
      {% endif %}
    {% endif %}
  </span>
  {% set start = paragraph.field_kore_start_year.value %}
  {% set end = paragraph.field_kore_end_year.value %}
  {% if start or end %}
    <span class="kore--date">
      {{ start }}{% if start and end %} → {% endif %}{{ end }}
    </span>
  {% endif %}
</li>
